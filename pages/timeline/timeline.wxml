<!-- 足迹 / 时间轴 -->
<view class="page-timeline">

  <!-- 年代快速跳转 -->
  <scroll-view class="era-nav" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="era-nav-inner">
      <view
        wx:for="{{eras}}"
        wx:key="year"
        class="era-chip {{currentEra === item.year ? 'era-chip-active' : ''}}"
        bindtap="jumpToEra"
        data-year="{{item.year}}"
      >
        {{item.year}}
      </view>
    </view>
  </scroll-view>

  <!-- 时间轴主体 -->
  <scroll-view class="timeline-scroll" scroll-y scroll-into-view="era-{{scrollToYear}}">
    <view class="timeline-body">
      <view class="timeline-line"></view>
      <view
        wx:for="{{events}}"
        wx:key="id"
        id="era-{{item.year}}"
        class="timeline-event {{index % 2 === 0 ? 'event-left' : 'event-right'}}"
      >
        <timeline-item
          year="{{item.year}}"
          title="{{item.title}}"
          content="{{item.content}}"
          position="{{index % 2 === 0 ? 'left' : 'right'}}"
        />
      </view>
    </view>
  </scroll-view>

</view>
