<view class="login-page">
  <view class="login-bg login-bg-left"></view>
  <view class="login-bg login-bg-right"></view>

  <view class="login-card card-paper">
    <!-- Step 1: Welcome 欢迎页 -->
    <view wx:if="{{loginStep === 'welcome'}}">
      <view class="login-brand">
        <view class="brand-mark">健</view>
        <text class="brand-title">健雄书韵</text>
        <text class="brand-subtitle">微信授权登录</text>
      </view>

      <view class="profile-preview">
        <view class="preview-avatar preview-avatar-fallback">
          <text class="preview-avatar-text">{{previewProfile.avatarText}}</text>
        </view>
        <text class="preview-name">{{previewProfile.nickName}}</text>
        <text class="preview-signature">{{previewProfile.signature}}</text>
      </view>

      <view class="benefit-list">
        <view class="benefit-item" wx:for="{{benefits}}" wx:key="title">
          <text class="benefit-title">{{item.title}}</text>
          <text class="benefit-desc">{{item.desc}}</text>
        </view>
      </view>

      <view class="login-actions">
        <view class="btn-primary login-btn {{loading ? 'loading' : ''}}" bindtap="handleLogin">
          {{loading ? '获取凭证中...' : '微信一键登录'}}
        </view>
        <view class="btn-outline login-back-btn" bindtap="goProfile">返回个人中心</view>
      </view>

      <text wx:if="{{errorMessage}}" class="login-error">{{errorMessage}}</text>
    </view>

    <!-- Step 2: Profile 头像昵称填写页 -->
    <view wx:if="{{loginStep === 'profile'}}" class="profile-fill-group">
      <text class="profile-fill-title">完善你的个人资料</text>
      <text class="profile-fill-desc">头像将自动使用昵称第一个字</text>

      <view class="avatar-section">
        <view class="avatar-preview avatar-preview-placeholder">
          <text class="avatar-placeholder-text">{{nickName ? nickName.charAt(0) : previewProfile.avatarText}}</text>
        </view>
        <view class="avatar-options">
          <text class="avatar-help-text">昵称会作为你的头像展示</text>
        </view>
      </view>

      <!-- 昵称输入 -->
      <input
        class="nickname-input"
        type="nickname"
        placeholder="请输入昵称"
        bindblur="onNicknameBlur"
        maxlength="20"
        placeholder-class="nickname-input-placeholder"
      />

      <view class="profile-actions">
        <view class="btn-primary {{loading ? 'loading' : ''}}" bindtap="onConfirmProfile">
          {{loading ? '登录中...' : '完成并登录'}}
        </view>
        <view class="btn-outline" bindtap="handleLogin">重新获取凭证</view>
      </view>

      <text wx:if="{{errorMessage}}" class="login-error">{{errorMessage}}</text>
    </view>

    <!-- Step 3: Process 登录处理页 -->
    <view wx:if="{{loginStep === 'process'}}" class="process-group">
      <view class="process-loading">
        <view class="spinner"></view>
        <text class="process-text">登录中...</text>
      </view>
    </view>
  </view>
</view>