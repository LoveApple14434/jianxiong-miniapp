.login-page {
  min-height: 100vh;
  padding: 72rpx 32rpx 48rpx;
  background: linear-gradient(180deg, #1A0F2E 0%, #3D1B62 42%, #F8F5F0 42%, #F8F5F0 100%);
  position: relative;
  overflow: hidden;
}

.login-bg {
  position: absolute;
  border-radius: 50%;
  filter: blur(8rpx);
}

.login-bg-left {
  width: 280rpx;
  height: 280rpx;
  background: rgba(201, 169, 110, 0.18);
  left: -100rpx;
  top: 120rpx;
}

.login-bg-right {
  width: 360rpx;
  height: 360rpx;
  background: rgba(91, 45, 142, 0.18);
  right: -160rpx;
  top: 0;
}

.login-card {
  position: relative;
  z-index: 1;
  padding: 40rpx 32rpx 44rpx;
  border-radius: 32rpx;
  box-shadow: 0 18rpx 48rpx rgba(26, 15, 46, 0.18);
}

.login-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-mark {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B2D8E, #C9A96E);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(91, 45, 142, 0.24);
}

.brand-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #2D2D2D;
}

.brand-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8C8C8C;
}

.profile-preview {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-avatar {
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(91, 45, 142, 0.08);
  box-shadow: 0 10rpx 30rpx rgba(91, 45, 142, 0.12);
  background: #F5EFE6;
}

.preview-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #5B2D8E, #C9A96E);
}

.preview-avatar-text {
  color: #FFFFFF;
  font-size: 64rpx;
  font-weight: 700;
}

.preview-name {
  margin-top: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2D2D;
}

.preview-signature {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8C8C8C;
  text-align: center;
  line-height: 1.8;
}

.benefit-list {
  margin-top: 36rpx;
}

.benefit-item {
  padding: 24rpx 0;
  border-top: 1rpx solid #EFE7DB;
}

.benefit-item:first-child {
  border-top: none;
}

.benefit-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #5B2D8E;
}

.benefit-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8C8C8C;
  line-height: 1.7;
}

.login-actions {
  margin-top: 34rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.login-btn,
.login-back-btn {
  width: 100%;
  box-sizing: border-box;
}

.login-btn.loading {
  opacity: 0.85;
}

.login-error {
  display: block;
  margin-top: 20rpx;
  color: #B23A48;
  font-size: 24rpx;
  text-align: center;
}

/* ========== 头像昵称填写页（profile 步骤） ========== */
.profile-fill-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: calc(100vh - 120rpx); 
  position: relative;
  z-index: 1;
  padding: 40rpx 32rpx 44rpx;
  border-radius: 32rpx;
}

.profile-fill-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-top: 20rpx;
  text-align: center;
}

.profile-fill-desc {
  display: block;
  font-size: 24rpx;
  color: #8C8C8C;
  text-align: center;
  margin-top: 12rpx;
  line-height: 1.8;
}

/* 头像按钮 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 32rpx;
}

.avatar-choose-btn {
  width: 168rpx;
  height: 168rpx;
  padding: 0;
  background: transparent;
  border-radius: 50%;
  border: 4rpx solid rgba(91, 45, 142, 0.08);
  box-shadow: 0 10rpx 30rpx rgba(91, 45, 142, 0.12);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-choose-btn::after {
  border: none;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-preview-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B2D8E, #C9A96E);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-text {
  color: #FFFFFF;
  font-size: 64rpx;
  font-weight: 700;
}

.avatar-options {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.avatar-help-text {
  font-size: 20rpx;
  color: #8C8C8C;
}

.avatar-wechat-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
}

/* 昵称输入框 */
.nickname-input {
  width: 100%;
  box-sizing: border-box;
  margin-top: 28rpx;
  padding: 16rpx 24rpx;
  height: 88rpx;
  font-size: 28rpx;
  line-height: 56rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E8E2D8;
  background: #FFFFFF;
  color: #2D2D2D;
}

.nickname-input-placeholder {
  color: #B0B0B0;
}

/* 资料完成按钮组 */
.profile-actions {
  width: 100%;
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.profile-actions .btn-primary,
.profile-actions .btn-outline {
  width: 100%;
  box-sizing: border-box;
}

/* ========== 登录处理页（process 步骤） ========== */
.process-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 360rpx;
}

.process-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(91, 45, 142, 0.1);
  border-top-color: #5B2D8E;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.process-text {
  font-size: 28rpx;
  color: #8C8C8C;
}