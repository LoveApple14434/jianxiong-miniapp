<!-- 我的 / 个人中心 -->
<view class="page-profile">

  <!-- 个人信息头部 -->
  <view class="profile-header">
    <view class="profile-avatar">
      <text class="avatar-text">健</text>
    </view>
    <text class="profile-name">健雄学子</text>
    <text class="profile-desc">共读 12 天</text>
  </view>

  <!-- 数据看板 -->
  <view class="stats-board">
    <view class="stat-item">
      <text class="stat-number">5</text>
      <text class="stat-label">已读章</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">12</text>
      <text class="stat-label">笔记数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">32</text>
      <text class="stat-label">获赞数</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="container">
    <view class="menu-list card">
      <view class="menu-item" wx:for="{{menuList}}" wx:key="id" bindtap="onMenuTap" data-id="{{item.id}}">
        <view class="menu-left">
          <text class="menu-icon">{{item.icon}}</text>
          <text class="menu-text">{{item.title}}</text>
        </view>
        <text class="menu-arrow">→</text>
      </view>
    </view>
  </view>

</view>
