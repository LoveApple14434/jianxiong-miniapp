<!-- 我的 / 个人中心 -->
<view class="page-profile">

  <!-- 个人信息头部 -->
  <view class="profile-header">
    <view class="profile-glow"></view>
    <view wx:if="{{isLogin}}" class="profile-identity">
      <view class="profile-avatar profile-avatar-placeholder">
        <text class="avatar-text">{{userInfo.avatarText}}</text>
      </view>
      <text class="profile-name">{{userInfo.nickName || '健雄学子'}}</text>
      <text class="profile-desc">{{userInfo.lastLoginText}}</text>
    </view>
    <view wx:else class="profile-identity guest-state">
      <view class="profile-avatar profile-avatar-placeholder">
        <text class="avatar-text">健</text>
      </view>
      <text class="profile-name">未登录</text>
      <text class="profile-desc">登录后可同步笔记、收藏与共读进度</text>
      <view class="profile-entry-row">
        <view class="btn-primary profile-entry-btn" bindtap="handleLogin">微信一键登录</view>
      </view>
    </view>
  </view>

  <!-- 数据看板 -->
  <view class="stats-board">
    <view class="stat-item" wx:for="{{statList}}" wx:key="label">
      <text class="stat-number">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
      <view class="stat-divider" wx:if="{{index < statList.length - 1}}"></view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="container">
    <view wx:if="{{isLogin}}" class="profile-actions card">
      <view class="btn-outline profile-logout-btn" bindtap="handleLogout">退出登录</view>
    </view>

    <view wx:else class="auth-tip card card-paper">
      <text class="auth-tip-title">登录后解锁个人中心</text>
      <text class="auth-tip-text">同步阅读进度、管理书摘笔记，并保留你的共读足迹。</text>
    </view>

    <view class="menu-list card">
      <view class="menu-item" wx:for="{{menuList}}" wx:key="id" bindtap="onMenuTap" data-id="{{item.id}}">
        <view class="menu-left">
          <text class="menu-icon">{{item.icon}}</text>
          <text class="menu-text">{{item.title}}</text>
        </view>
        <text class="menu-arrow">→</text>
      </view>
    </view>
  </view>

</view>
