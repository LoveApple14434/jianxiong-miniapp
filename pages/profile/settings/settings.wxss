.page-settings {
  min-height: 100vh;
  padding: 32rpx;
  background: #F8F5EF;
}

.setting-card {
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 45, 142, 0.08);
  margin-bottom: 32rpx;
}

.setting-item {
  margin-bottom: 32rpx;
}

.setting-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.setting-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #F8F5EF;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2D2D2D;
}

.save-btn {
  margin-top: 20rpx;
  background: #5B2D8E;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 999rpx;
}

.reset-btn {
  background: #FFF1F0;
  color: #D93026;
  font-size: 28rpx;
  border-radius: 999rpx;
}
