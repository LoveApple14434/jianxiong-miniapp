.page-favorites {
  min-height: 100vh;
  padding: 32rpx;
  background: #F8F5EF;
}

.empty {
  margin-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5B2D8E;
}

.empty-desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #8C8C8C;
}

.favorite-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.favorite-card {
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 45, 142, 0.08);
}

.favorite-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #5B2D8E;
}

.favorite-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #2D2D2D;
  line-height: 1.6;
}

.favorite-meta {
  display: flex;
  gap: 32rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #8C8C8C;
}

.remove-btn {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #5B2D8E;
  background: #F3ECFA;
  border-radius: 999rpx;
}
