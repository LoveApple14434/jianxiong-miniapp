.page-progress {
  min-height: 100vh;
  padding: 32rpx;
  background: #F8F5EF;
}

.progress-card,
.chapter-card {
  padding: 40rpx 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 45, 142, 0.08);
  margin-bottom: 32rpx;
}

.progress-title,
.chapter-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #5B2D8E;
  margin-bottom: 16rpx;
}

.progress-chapter {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

.progress-bar {
  width: 100%;
  height: 24rpx;
  background: #EEE7F5;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #5B2D8E, #C9A96E);
  border-radius: 999rpx;
}

.progress-percent {
  display: block;
  margin-top: 24rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #5B2D8E;
}

.progress-info {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666666;
}

.chapter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0EBE3;
}

.chapter-item:last-child {
  border-bottom: none;
}

.chapter-name {
  font-size: 28rpx;
  color: #2D2D2D;
}

.chapter-status {
  font-size: 24rpx;
  color: #B0B0B0;
}

.chapter-status.finished {
  color: #C9A96E;
}
