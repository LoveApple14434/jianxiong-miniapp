/* 共读页面 */

.page-reading {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 章节导航 */
.chapter-nav {
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
  padding: 20rpx 0;
  flex-shrink: 0;
}

.chapter-nav-inner {
  display: inline-flex;
  gap: 12rpx;
  padding: 0 32rpx;
}

.chapter-tab-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.chapter-tab {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-xl);
  font-size: 24rpx;
  color: var(--color-text-sub);
  background: var(--color-bg);
  white-space: nowrap;
}

.chapter-tab-active {
  background: var(--color-primary);
  color: var(--color-white);
  font-weight: 600;
}

.chapter-fav-btn {
  font-size: 28rpx;
  opacity: 0.5;
  transition: opacity 0.2s, color 0.2s;
  padding: 8rpx;
  color: #8C8C8C;
}

.chapter-fav-btn:active {
  opacity: 1;
}

.chapter-fav-btn.fav-active {
  opacity: 1;
  color: #e64340;
}

/* 阅读区 */
.reading-scroll {
  flex: 1;
}

/* 书摘卡片 */
.excerpt-card {
  padding: 40rpx 36rpx;
}

.excerpt-chapter {
  font-size: 26rpx;
  font-weight: 700;
  display: block;
  text-align: center;
}

.excerpt-text {
  display: block;
  text-align: justify;
  margin: 20rpx 0;
}

.excerpt-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

/* 笔记列表 */
.note-list {
  padding-bottom: 160rpx;
}

.note-item {
  padding: 28rpx;
}

.note-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.note-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: var(--color-white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.note-info {
  display: flex;
  flex-direction: column;
}

.note-content {
  line-height: 1.8;
}

.note-footer {
  margin-top: 16rpx;
  text-align: right;
}
/* 点赞交互样式 */
.note-footer {
  margin-top: 16rpx;
  text-align: right;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  margin-left: auto;
  border-radius: 30rpx;
  transition: background-color 0.2s;
}

.note-footer:active {
  background-color: rgba(91, 45, 142, 0.05);
}

.like-icon {
  font-size: 28rpx;
  opacity: 0.4;
  transform: scale(1);
  transition: all 0.2s ease-out;
  display: inline-block;
}

.like-icon.liked {
  opacity: 1;
  color: #e64340;
  transform: scale(1.3);
}

.like-count {
  transition: color 0.2s;
}

.like-icon.liked + .like-count {
  color: #e64340;
  font-weight: 600;
}
