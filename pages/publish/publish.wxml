<!-- pages/publish/publish.wxml -->
<view class="publish-container">
  <view class="topic-section">
    <text class="label">选择话题</text>
    <view class="topic-list">
      <view
        wx:for="{{topics}}"
        wx:key="id"
        class="topic-item {{selectedTopicId === item.id ? 'active' : ''}}"
        bindtap="onTopicChange"
        data-id="{{item.id}}"
      >
        #{{item.name}}
      </view>
    </view>
  </view>

  <view class="content-section">
    <textarea class="content-input" placeholder="分享你的想法..." value="{{content}}" bindinput="onContentInput" auto-focus maxlength="500"></textarea>
    <view class="word-count">{{content.length}}/500</view>
  </view>

  <view class="image-section" bindtap="chooseImage">
    <text class="add-image">+ 添加图片（暂未开放）</text>
  </view>

  <button class="publish-btn" type="primary" bindtap="publish">发布</button>
</view>