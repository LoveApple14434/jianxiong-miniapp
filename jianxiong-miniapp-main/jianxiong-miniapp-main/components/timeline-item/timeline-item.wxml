<view class="tl-item tl-{{position}} {{visible ? 'tl-visible' : 'tl-hidden'}}">
  <!-- 三栏布局：左区 | 中轴 | 右区 -->
  <view class="tl-left-area">
    <view class="tl-card card" wx:if="{{position === 'left'}}">
      <view class="tl-year-badge"><text>{{year}}</text></view>
      <text class="tl-title">{{title}}</text>
      <text class="tl-content">{{content}}</text>
    </view>
  </view>

  <view class="tl-center">
    <view class="tl-dot-wrap">
      <view class="tl-dot"></view>
      <view class="tl-dot-ring"></view>
      <!-- 枝节：从圆点向外延伸，触碰到卡片即止 -->
      <view class="tl-branch"></view>
    </view>
  </view>

  <view class="tl-right-area">
    <view class="tl-card card" wx:if="{{position === 'right'}}">
      <view class="tl-year-badge"><text>{{year}}</text></view>
      <text class="tl-title">{{title}}</text>
      <text class="tl-content">{{content}}</text>
    </view>
  </view>
</view>
