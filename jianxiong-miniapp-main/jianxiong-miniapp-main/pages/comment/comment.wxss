page {
  --primary: #5B2D8E;
  --accent: #C9A96E;
  --bg: #F8F5F0;
  --text: #2D2D2D;
  --subText: #8C8C8C;
  --lightGold: #E8D5B5;
  --white: #fff;
  --border: #e0d8cc;
  background: var(--bg);
  font-size: 28rpx;
}

.page-comment {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 帖子卡片 */
.post-card {
  background: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--lightGold);
}
.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--primary);
  color: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  margin-right: 16rpx;
}
.user { flex:1; }
.name {
  display: block;
  font-weight: bold;
  color: var(--text);
}
.time {
  font-size: 24rpx;
  color: var(--subText);
}
.tag {
  background: var(--lightGold);
  color: var(--primary);
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.content {
  line-height: 1.7;
  color: var(--text);
}

/* 评论列表 */
.comment-list {
  background: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid var(--lightGold);
}
.title {
  font-weight: bold;
  margin-bottom: 20rpx;
  color: var(--primary);
}
.empty {
  color: var(--subText);
  text-align: center;
  padding: 40rpx 0;
}
.comment-item {
  display: flex;
  margin-bottom: 24rpx;
}
.c-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--primary);
  color: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.c-body { flex:1; }
.c-name {
  font-weight: bold;
  margin-bottom: 4rpx;
  color: var(--text);
}
.c-content {
  line-height: 1.6;
  margin-bottom: 4rpx;
}
.c-time {
  font-size: 24rpx;
  color: var(--subText);
}

/* 底部回复栏 */
.reply-bar {
  position: fixed;
  bottom: 0; left:0;
  width:100%;
  background: var(--white);
  display: flex;
  align-items: center;
  padding:16rpx 20rpx;
  box-sizing: border-box;
  border-top:1rpx solid var(--border);
}
.input {
  flex:1;
  background: var(--bg);
  border-radius:30rpx;
  padding:12rpx 20rpx;
  font-size:26rpx;
  border:1rpx solid var(--lightGold);
}
.btn {
  margin-left:16rpx;
  background: var(--primary);
  color: var(--accent);
  border-radius:30rpx;
  padding:10rpx 20rpx;
  font-size:26rpx;
  border:1rpx solid var(--accent);
}

.c-name-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.del-comment {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 8rpx;
}
.del-comment:active {
  color: #5B2D8E;
}
.del-btn {
  color: #999;
}