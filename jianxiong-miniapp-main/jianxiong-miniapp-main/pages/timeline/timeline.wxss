/* 时间轴页面 */

.page-timeline {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 年代导航 */
.era-nav {
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
  padding: 20rpx 0;
  flex-shrink: 0;
}

.era-nav-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 32rpx;
}

.era-chip {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-xl);
  font-size: 24rpx;
  color: var(--color-text-sub);
  background: var(--color-bg);
  white-space: nowrap;
  font-weight: 500;
}

.era-chip-active {
  background: var(--color-primary);
  color: var(--color-white);
}

/* 时间轴主体 */
.timeline-scroll {
  flex: 1;
  padding: 40rpx 0;
}

.timeline-body {
  position: relative;
  padding: 0 32rpx;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.timeline-line {
  position: absolute;
  /* 左区 flex:1, 中轴列 60rpx, 右区 flex:1
     中轴中心 = 50% 的内容宽度 */
  left: 50%;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(to bottom, var(--color-accent), var(--color-primary), var(--color-accent));
  transform: translateX(-50%);
}

.timeline-event {
  margin-bottom: 48rpx;
  position: relative;
}
