<view class="page-create">
  <!-- 标题栏 -->
  <view class="navbar">
    <view bindtap="goBack">取消</view>
    <text>发布帖子</text>
    <view class="submit" bindtap="doSubmit">发布</view>
  </view>

  <!-- 内容输入 -->
  <view class="form-item">
    <textarea 
      placeholder="分享你的想法..." 
      value="{{content}}" 
      bindinput="onInputContent"
      maxlength="500"
    ></textarea>
  </view>

  <!-- 选择图片 -->
  <view class="form-item">
    <text class="label">添加图片（可选）</text>
    <view class="image-list">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill"></image>
        <view class="del" data-index="{{index}}" bindtap="delImage">×</view>
      </view>
      <view class="add-img" bindtap="chooseImage" wx:if="{{images.length < 3}}">
        <text>+</text>
      </view>
    </view>
  </view>

  <!-- 选择话题 -->
  <view class="form-item">
    <text class="label">选择话题</text>
    <view class="topic-list">
      <view 
        wx:for="{{topicList}}" 
        wx:key="id"
        class="topic {{selectedTopic === item.id ? 'active' : ''}}"
        bindtap="selectTopic"
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </view>
  </view>
</view>