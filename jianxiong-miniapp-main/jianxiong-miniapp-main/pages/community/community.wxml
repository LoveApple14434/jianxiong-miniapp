<view class="page-community">

<!-- 话题标签 -->
<scroll-view class="topic-nav" scroll-x enhanced show-scrollbar="{{false}}">
  <view class="topic-nav-inner">
    <view
      wx:for="{{topics}}"
      wx:key="id"
      class="topic-tag {{currentTopic === item.id ? 'topic-tag-active' : ''}}"
      bindtap="switchTopic"
      data-id="{{item.id}}"
    >
      #{{item.name}}
    </view>
  </view>
</scroll-view>

<!-- 帖子列表 -->
<scroll-view class="post-scroll" scroll-y>
  <view class="container">

    <view class="empty-state" wx:if="{{filteredPosts.length === 0}}">
      <text class="empty-icon">📝</text>
      <text class="empty-text">这个分区还没有帖子，来发第一条吧</text>
    </view>

    <view class="post-item card" wx:for="{{filteredPosts}}" wx:key="id">
      <view class="post-header">
        <view class="post-avatar">
          <image wx:if="{{item.avatar && item.avatar.startsWith('http')}}" src="{{item.avatar}}" mode="aspectFill"></image>
          <text wx:else>{{item.avatar}}</text>
        </view>

        <view class="post-user-info">
          <text class="text-subtitle">{{item.name}}</text>
          <text class="text-caption">{{item.time}}</text>
        </view>
        <view class="tag-stamp">{{item.tag}}</view>
      </view>

      <text class="post-content text-body">{{item.content}}</text>

      <view class="post-images" wx:if="{{item.images && item.images.length > 0}}">
        <image 
          wx:for="{{item.images}}" 
          wx:key="*this"
          src="{{item}}"
          class="post-image"
          mode="aspectFill"
        ></image>
      </view>

      <view class="post-actions">
        <view class="post-action" bindtap="doLike" data-id="{{item.id}}">
          <text style="{{item.isLiked ? 'color:red' : ''}}">❤ {{item.likes}}</text>
        </view>
        <view class="post-action" bindtap="openComment" data-id="{{item.id}}">
          <text>💬 {{item.comments}}</text>
        </view>
        <view class="post-action del-btn" wx:if="{{item.name === myName}}" bindtap="delPost" data-id="{{item.id}}">
          <text>🗑 删除</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<view class="fab" bindtap="createPost">
  <text>✍</text>
</view>

</view>