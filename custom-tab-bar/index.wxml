<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-bar-item {{selected === index ? 'active' : ''}}"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <!-- 图标区域 -->
    <view class="tab-icon-wrap">
      <!-- 发现 -->
      <view wx:if="{{item.iconName === 'discover'}}" class="tab-icon">
        <view class="icon-discover {{selected === index ? 'icon-active' : ''}}">
          <view class="icon-house"></view>
        </view>
      </view>
      <!-- 足迹 -->
      <view wx:elif="{{item.iconName === 'timeline'}}" class="tab-icon">
        <view class="icon-timeline {{selected === index ? 'icon-active' : ''}}">
          <view class="icon-clock"></view>
        </view>
      </view>
      <!-- 共读 -->
      <view wx:elif="{{item.iconName === 'reading'}}" class="tab-icon">
        <view class="icon-reading {{selected === index ? 'icon-active' : ''}}">
          <view class="icon-book"></view>
        </view>
      </view>
      <!-- 社区 -->
      <view wx:elif="{{item.iconName === 'community'}}" class="tab-icon">
        <view class="icon-community {{selected === index ? 'icon-active' : ''}}">
          <view class="icon-chat"></view>
        </view>
      </view>
      <!-- 我的 -->
      <view wx:elif="{{item.iconName === 'profile'}}" class="tab-icon">
        <view class="icon-profile {{selected === index ? 'icon-active' : ''}}">
          <view class="icon-user"></view>
        </view>
      </view>
      <!-- 选中指示点 -->
      <view class="tab-dot" wx:if="{{selected === index}}"></view>
    </view>
    <text class="tab-text {{selected === index ? 'tab-text-active' : ''}}">{{item.text}}</text>
  </view>
</view>
